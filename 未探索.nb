  RowBox[{"ClearAll", "[", "\"\<Global`*\>\"", "]"}], 
  "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"T0", "=", "1"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"\[Omega]0", "=", 
