Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"ClearAll", "[", "\"\<Global`*\>\"", "]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"SetOptions", "[", 
    RowBox[{"InverseFourierTransform", ",", 
     RowBox[{"FourierParameters", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{"0", ",", "1"}], "}"}]}]}], "]"}], ";"}], 
  "\n"}], "\[IndentingNewLine]", 
 RowBox[{"InverseFourierTransform", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"(", 
     RowBox[{"2", " ", 
      RowBox[{"Sin", "[", 
       RowBox[{"3", " ", 
        RowBox[{"(", 
         RowBox[{"\[Omega]", "-", 
          RowBox[{"2", " ", "Pi"}]}], ")"}]}], "]"}]}], ")"}], "/", 
    RowBox[{"(", 
     RowBox[{"\[Omega]", "-", 
      RowBox[{"2", " ", "Pi"}]}], ")"}]}], ",", "\[Omega]", ",", "t"}], 
  "]"}]}], "Input",
 CellChangeTimes->{{3.985232314249169*^9, 3.9852323142511606`*^9}},
 CellLabel->"In[86]:=",ExpressionUUID->"f02254cb-e600-4eae-9ab7-d8f066cd3ab2"],

Cell[BoxData[
 RowBox[{
  SqrtBox[
   FractionBox["\[Pi]", "2"]], " ", 
  RowBox[{"(", 
   RowBox[{
    RowBox[{"Sign", "[", 
     RowBox[{"3", "-", "t"}], "]"}], "+", 
    RowBox[{"Sign", "[", 
     RowBox[{"3", "+", "t"}], "]"}]}], ")"}], " ", 
  RowBox[{"(", 
   RowBox[{
    RowBox[{"Cos", "[", 
     RowBox[{"2", " ", "\[Pi]", " ", "t"}], "]"}], "-", 
    RowBox[{"\[ImaginaryI]", " ", 
     RowBox[{"Sin", "[", 
      RowBox[{"2", " ", "\[Pi]", " ", "t"}], "]"}]}]}], ")"}]}]], "Output",
 CellChangeTimes->{3.9852323150466604`*^9},
 CellLabel->"Out[88]=",ExpressionUUID->"7ef44ddd-01f2-4975-8d33-4181d784da6b"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"ClearAll", "[", "\"\<Global`*\>\"", "]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"SetOptions", "[", 
    RowBox[{"FourierTransform", ",", 
     RowBox[{"FourierParameters", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{"0", ",", "1"}], "}"}]}]}], "]"}], ";"}], 
  "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"f", "[", 
    RowBox[{"t_", ",", "b_"}], "]"}], ":=", 
   RowBox[{"Piecewise", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"{", 
       RowBox[{"2", ",", 
        RowBox[{
         RowBox[{"Abs", "[", "t", "]"}], "\[LessEqual]", "b"}]}], "}"}], 
      "}"}], ",", "0"}], "]"}]}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"F", "[", 
