 RowBox[{
  RowBox[{
   RowBox[{"C", "=", "1"}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"h", "[", "t_", "]"}], ":=", 
    RowBox[{
     RowBox[{"f", "[", 
      RowBox[{"t", ",", "b"}], "]"}], " ", 
     RowBox[{"Exp", "[", 
      RowBox[{"I", " ", "C", " ", 
       RowBox[{"t", "^", "2"}]}], "]"}]}]}], ";"}], 
  "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"H", "[", "\[Omega]_", "]"}], "=", 
    RowBox[{"FourierTransform", "[", 
     RowBox[{
      RowBox[{"h", "[", "t", "]"}], ",", "t", ",", "\[Omega]"}], "]"}]}], 
   ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"Evaluate", "[", 
    RowBox[{"Abs", "[", 
     RowBox[{"H", "[", "\[Omega]", "]"}], "]"}], "]"}], ",", 
